<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TokenLens</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="bg-body-tertiary">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/"><i class="bi bi-braces me-2"></i>TokenLens</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link active" href="/">Tokenizer</a>
        <a class="nav-link" href="/learn">What is Tokenization?</a>
      </div>
    </div>
  </nav>

  <div class="container py-4">

    <!-- Input card -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="card-title mb-0">Enter Text to Tokenize</h5>
          <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                    data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-collection me-1"></i>Load Sample
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="min-width:210px">
              <li><h6 class="dropdown-header">Prose</h6></li>
              <li><a class="dropdown-item small" href="#" data-sample="prose-small">
                <span class="badge bg-secondary me-1">S</span>Short sentence</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="prose-medium">
                <span class="badge bg-secondary me-1">M</span>Technical paragraph</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="prose-large">
                <span class="badge bg-secondary me-1">L</span>Report section</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><h6 class="dropdown-header">JavaScript</h6></li>
              <li><a class="dropdown-item small" href="#" data-sample="js-small">
                <span class="badge bg-warning text-dark me-1">S</span>Small function</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="js-medium">
                <span class="badge bg-warning text-dark me-1">M</span>Class &amp; methods</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="js-large">
                <span class="badge bg-warning text-dark me-1">L</span>Express module</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><h6 class="dropdown-header">Python</h6></li>
              <li><a class="dropdown-item small" href="#" data-sample="py-small">
                <span class="badge bg-primary me-1">S</span>Small function</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="py-medium">
                <span class="badge bg-primary me-1">M</span>Dataclass</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="py-large">
                <span class="badge bg-primary me-1">L</span>Vector store</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><h6 class="dropdown-header">Other Languages</h6></li>
              <li><a class="dropdown-item small" href="#" data-sample="rust-small">
                <span class="badge bg-danger me-1">Rust</span>Struct + impl</a></li>
              <li><a class="dropdown-item small" href="#" data-sample="sql-small">
                <span class="badge bg-info text-dark me-1">SQL</span>Analytics query</a></li>
            </ul>
          </div>
        </div>
        <textarea id="inputText" class="form-control font-monospace mb-2" rows="6"
          placeholder="Paste or type any text here…" maxlength="50000"></textarea>
        <div class="d-flex justify-content-between align-items-center">
          <small class="text-muted"><span id="charCount">0</span> / 50,000 characters</small>
          <div class="d-flex gap-2">
            <button id="btnClear" class="btn btn-outline-secondary btn-sm">
              <i class="bi bi-x-circle me-1"></i>Clear
            </button>
            <button id="btnCompare" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-bar-chart-line me-1"></i>Compare All Models
            </button>
            <button id="btnTokenize" class="btn btn-primary btn-sm" disabled>
              <i class="bi bi-play-fill me-1"></i>Tokenize
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Model selector -->
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h6 class="card-title mb-3">Select Model</h6>
        <ul class="nav nav-tabs mb-3" id="providerTabs" role="tablist">
          <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-openai">OpenAI</button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-anthropic">Anthropic</button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-meta">Meta</button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-google">Google</button></li>
          <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-mistral">Mistral</button></li>
        </ul>

        <div class="tab-content">
          <!-- OpenAI -->
          <div class="tab-pane fade show active" id="tab-openai">
            <div class="d-flex flex-wrap gap-2">
              <% ['gpt-4o','gpt-4o-mini','gpt-3.5-turbo','o1','o3'].forEach(id => { %>
                <input type="radio" class="btn-check model-radio" name="model" id="m-<%=id%>" value="<%=id%>" <%=id==='gpt-4o'?'checked':''%>>
                <label class="btn btn-outline-secondary btn-sm" for="m-<%=id%>"><%=pricing[id].label%></label>
              <% }) %>
            </div>
          </div>
          <!-- Anthropic -->
          <div class="tab-pane fade" id="tab-anthropic">
            <div class="d-flex flex-wrap gap-2">
              <% ['claude-3-5-sonnet','claude-3-haiku','claude-3-opus'].forEach(id => { %>
                <input type="radio" class="btn-check model-radio" name="model" id="m-<%=id%>" value="<%=id%>">
                <label class="btn btn-outline-secondary btn-sm" for="m-<%=id%>"><%=pricing[id].label%></label>
              <% }) %>
            </div>
          </div>
          <!-- Meta -->
          <div class="tab-pane fade" id="tab-meta">
            <div class="d-flex flex-wrap gap-2">
              <% ['llama-2','llama-3'].forEach(id => { %>
                <input type="radio" class="btn-check model-radio" name="model" id="m-<%=id%>" value="<%=id%>">
                <label class="btn btn-outline-secondary btn-sm" for="m-<%=id%>"><%=pricing[id].label%></label>
              <% }) %>
            </div>
          </div>
          <!-- Google -->
          <div class="tab-pane fade" id="tab-google">
            <div class="d-flex flex-wrap gap-2">
              <% ['gemini-1-5-pro','gemini-2-5-flash'].forEach(id => { %>
                <input type="radio" class="btn-check model-radio" name="model" id="m-<%=id%>" value="<%=id%>">
                <label class="btn btn-outline-secondary btn-sm" for="m-<%=id%>"><%=pricing[id].label%></label>
              <% }) %>
            </div>
          </div>
          <!-- Mistral -->
          <div class="tab-pane fade" id="tab-mistral">
            <div class="d-flex flex-wrap gap-2">
              <% ['mistral-large','mistral-small'].forEach(id => { %>
                <input type="radio" class="btn-check model-radio" name="model" id="m-<%=id%>" value="<%=id%>">
                <label class="btn btn-outline-secondary btn-sm" for="m-<%=id%>"><%=pricing[id].label%></label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading spinner -->
    <div id="spinner" class="text-center py-4 d-none">
      <div class="spinner-border text-primary" role="status"></div>
      <div class="mt-2 text-muted small">Tokenizing…</div>
    </div>

    <!-- Single model results -->
    <div id="results" class="d-none">
      <!-- Stats row -->
      <div class="row g-3 mb-4" id="statsRow"></div>

      <!-- Deep stats panel -->
      <div id="deepStats"></div>

      <!-- Token highlight -->
      <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-palette me-2"></i>Visual Token Breakdown</span>
          <span id="approxBadge" class="badge bg-warning text-dark d-none">~ Approximate</span>
        </div>
        <div class="card-body">
          <div id="tokenHighlight" class="token-display font-monospace"></div>
        </div>
      </div>

      <!-- Token ID sequence -->
      <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-hash me-2"></i>Token ID Sequence</span>
          <button class="btn btn-outline-secondary btn-sm" id="btnCopyIds">
            <i class="bi bi-clipboard me-1"></i>Copy
          </button>
        </div>
        <div class="card-body">
          <div id="tokenIdSequence" class="font-monospace text-break" style="font-size:0.85rem;line-height:1.8;"></div>
        </div>
      </div>

      <!-- Token IDs table -->
      <div class="card shadow-sm mb-4">
        <div class="card-header">
          <i class="bi bi-table me-2"></i>Token IDs
          <button class="btn btn-outline-secondary btn-sm float-end" id="btnCopyTable">
            <i class="bi bi-clipboard me-1"></i>Copy
          </button>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive" style="max-height:300px;overflow-y:auto;">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light sticky-top">
                <tr><th>#</th><th>Token</th><th>ID</th></tr>
              </thead>
              <tbody id="tokenTable"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Compare results -->
    <div id="compareResults" class="d-none">
      <h5 class="mb-3"><i class="bi bi-bar-chart-line me-2"></i>Model Comparison</h5>
      <div id="compareGrid" class="row g-3"></div>
    </div>

  </div>

  <footer class="text-center text-muted py-3 small border-top mt-4">
    TokenLens &mdash; all tokenization runs locally, no API keys required.
    Gemini, Llama&nbsp;3, and Mistral counts are approximate.
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
