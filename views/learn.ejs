<body class="bg-body-tertiary">

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/"><i class="bi bi-braces me-2"></i>TokenLens</a>
